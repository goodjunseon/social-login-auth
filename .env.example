# ==========================================
# Database (MySQL)
# ==========================================
# JDBC URL 예시: jdbc:mysql://호스트:포트/DB명?옵션
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/auth_db?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
# DB 접속 계정
SPRING_DATASOURCE_USERNAME=auth_user
# DB 접속 비밀번호
SPRING_DATASOURCE_PASSWORD=change_this_password

# ==========================================
# JWT
# ==========================================
# 최소 32바이트 이상 랜덤 문자열 권장 (절대 깃에 커밋 금지)
# 예시: openssl rand -base64 48
AUTH_JWT_SECRET=replace_with_strong_random_secret_min_32_bytes
# Access Token 만료(초) - 예시 3600 = 1시간
AUTH_JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
# Refresh Token 만료(초) - 예시 1209600 = 14일
AUTH_JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

# ==========================================
# Apple Login
# ==========================================
# Services ID (Identifier) 예시: com.example.auth.web
AUTH_APPLE_CLIENT_ID=com.example.auth.web
# Apple Developer Team ID (10자리 영숫자) 예시: A1B2C3D4E5
AUTH_APPLE_TEAM_ID=A1B2C3D4E5
# Sign in with Apple Key ID (10자리 영숫자) 예시: Z9Y8X7W6V5
AUTH_APPLE_KEY_ID=Z9Y8X7W6V5
# .p8 private key 내용 (개행은 \n 으로 이스케이프)
# 예시 형태:
# -----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----
AUTH_APPLE_PRIVATE_KEY=-----BEGIN_PRIVATE_KEY-----\nYOUR_KEY_CONTENT\n-----END_PRIVATE_KEY-----
# Apple 로그인 Redirect URI (Apple 콘솔 등록값과 정확히 일치)
AUTH_APPLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/apple
# Apple issuer는 일반적으로 고정
AUTH_APPLE_ISSUER=https://appleid.apple.com
# Apple audience는 보통 client-id와 동일
AUTH_APPLE_AUDIENCE=com.example.auth.web

# ==========================================
# Kakao Login
# ==========================================
# Kakao REST API 키
AUTH_KAKAO_CLIENT_ID=your_kakao_rest_api_key
# Kakao Client Secret (사용 시)
AUTH_KAKAO_CLIENT_SECRET=your_kakao_client_secret
# Kakao Redirect URI (카카오 콘솔 등록값과 정확히 일치)
AUTH_KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao
